{
  "name": "@harpoc/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Harpoc — direct and REST client modes",
  "license": "BUSL-1.1",
  "author": "Stefan Gönitzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarpocGH/harpoc.git",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@harpoc/shared": "workspace:*",
    "@harpoc/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  }
