{
  "name": "@harpoc/cli",
  "version": "1.0.0",
  "description": "CLI for Harpoc — vault init, secret management, server, audit",
  "license": "BUSL-1.1",
  "author": "Stefan Gönitzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarpocGH/harpoc.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "type": "module",
  "bin": {
    "harpoc": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@harpoc/shared": "workspace:*",
    "@harpoc/core": "workspace:*",
    "@harpoc/mcp-server": "workspace:*",
    "@harpoc/rest-api": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  }
}
