{
  "name": "harpoc",
  "version": "1.0.0",
  "description": "Zero-knowledge secret management for AI agents",
  "author": "Stefan Gönitzer",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarpocGH/harpoc.git"
  },
  "bugs": {
    "url": "https://github.com/HarpocGH/harpoc/issues"
  },
  "homepage": "https://github.com/HarpocGH/harpoc#readme",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "turbo run dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
